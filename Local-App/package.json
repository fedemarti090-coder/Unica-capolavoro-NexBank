{
  "name": "nex-bank",
  "version": "1.0.0",
  "description": "App NexBank",
  "main": "main.js",
  "author": "Federico Martinelli",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "keywords": [],
  "build": {
    "appId": "com.tuonome.pendoloarduino",
    "productName": "NexBank",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "node-localstorage": "^3.0.5",
    "nodemailer": "^8.0.7",
    "ogl": "^1.0.11",
    "qrcode": "^1.5.4",
    "three": "^0.183.2"
  }
}
